# ─── Athena RBBS Environment Variables ─────────────────────────────────────
# Copy to .env and fill in values for your deployment.

# ─── Engine (required) ─────────────────────────────────────────────────────
MODULE_PATH=./boards/golfsucks
SYSOP_HANDLE=YourHandle
SYSOP_PASSWORD=change-me-to-a-strong-password
ALLOWED_ORIGINS=https://your-client-domain.com

# ─── Server (required) ─────────────────────────────────────────────────────
ENGINE_PORT=3001
ENGINE_PUBLIC_HOST=your-engine-domain.com

# ─── Proxy (production) ───────────────────────────────────────────────────
# Set to "true" only when running behind nginx/Caddy reverse proxy
TRUST_PROXY=false
